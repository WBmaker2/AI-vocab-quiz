rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacherOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPublishedSet() {
      return resource.data.published == true;
    }

    function isMatchingLeaderboardPeriodType(periodType) {
      return periodType == 'week' || periodType == 'month' || periodType == 'year' || periodType == 'school_all';
    }

    function isNonNegativeNumber(value) {
      return (value is int || value is float) && value >= 0;
    }

    function isStudentBadgeId(badgeId) {
      return badgeId == 'first_challenge'
        || badgeId == 'listening_star'
        || badgeId == 'speaking_bravery'
        || badgeId == 'matching_speed'
        || badgeId == 'practice_keeper';
    }

    function isStudentProfileId(profileId, schoolId, grade, studentNameNormalized) {
      return profileId == schoolId + "__" + grade + "__" + studentNameNormalized;
    }

    function studentProfileNumber(data, fieldName) {
      return data.keys().hasAny([fieldName]) ? data[fieldName] : 0;
    }

    function isStudentProfileDocument(data) {
      return data.keys().hasOnly([
          'schoolId',
          'schoolName',
          'grade',
          'studentName',
          'studentNameNormalized',
          'totalSessions',
          'listeningSessions',
          'speakingSessions',
          'matchingSessions',
          'typingSessions',
          'listeningBestScore',
          'listeningBestCorrectCount',
          'speakingBestScore',
          'speakingBestCorrectCount',
          'matchingBestScore',
          'matchingBestTime',
          'typingBestScore',
          'typingBestCorrectCount',
          'typingBestAccuracy',
          'typingBestQuestionCount',
          'typingBestHintUsedCount',
          'typingBestCombo',
          'typingBestElapsedSeconds',
          'typingLastPlayedAt',
          'earnedBadges',
          'createdAt',
          'updatedAt'
        ])
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isNonNegativeNumber(data.totalSessions)
        && isNonNegativeNumber(data.listeningSessions)
        && isNonNegativeNumber(data.speakingSessions)
        && isNonNegativeNumber(data.matchingSessions)
        && isNonNegativeNumber(data.typingSessions)
        && isNonNegativeNumber(data.listeningBestScore)
        && isNonNegativeNumber(data.listeningBestCorrectCount)
        && isNonNegativeNumber(data.speakingBestScore)
        && isNonNegativeNumber(data.speakingBestCorrectCount)
        && isNonNegativeNumber(data.matchingBestScore)
        && isNonNegativeNumber(data.matchingBestTime)
        && isNonNegativeNumber(data.typingBestScore)
        && isNonNegativeNumber(data.typingBestCorrectCount)
        && isNonNegativeNumber(data.typingBestAccuracy)
        && isNonNegativeNumber(data.typingBestQuestionCount)
        && isNonNegativeNumber(data.typingBestHintUsedCount)
        && isNonNegativeNumber(data.typingBestCombo)
        && isNonNegativeNumber(data.typingBestElapsedSeconds)
        && (data.typingLastPlayedAt == null || data.typingLastPlayedAt is timestamp)
        && data.earnedBadges is list
        && data.earnedBadges.hasOnly([
          'first_challenge',
          'listening_star',
          'speaking_bravery',
          'matching_speed',
          'practice_keeper'
        ])
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isStudentProfileWrite(profileId) {
      return isStudentProfileDocument(request.resource.data)
        && isStudentProfileId(
          profileId,
          request.resource.data.schoolId,
          request.resource.data.grade,
          request.resource.data.studentNameNormalized
        );
    }

    function studentProfileSessionsMatchTotal(data) {
      return data.totalSessions
        == data.listeningSessions + data.speakingSessions + data.matchingSessions + data.typingSessions;
    }

    function isStudentProfileFirstSessionShape(data) {
      return studentProfileSessionsMatchTotal(data)
        && (
          (data.listeningSessions == 1 && data.speakingSessions == 0 && data.matchingSessions == 0 && data.typingSessions == 0)
          || (data.listeningSessions == 0 && data.speakingSessions == 1 && data.matchingSessions == 0 && data.typingSessions == 0)
          || (data.listeningSessions == 0 && data.speakingSessions == 0 && data.matchingSessions == 1 && data.typingSessions == 0)
          || (data.listeningSessions == 0 && data.speakingSessions == 0 && data.matchingSessions == 0 && data.typingSessions == 1)
        );
    }

    function isStudentProfileSingleSessionAdvance() {
      return request.resource.data.listeningSessions >= resource.data.listeningSessions
        && request.resource.data.speakingSessions >= resource.data.speakingSessions
        && request.resource.data.matchingSessions >= resource.data.matchingSessions
        && request.resource.data.typingSessions >= studentProfileNumber(resource.data, 'typingSessions')
        && request.resource.data.listeningSessions <= resource.data.listeningSessions + 1
        && request.resource.data.speakingSessions <= resource.data.speakingSessions + 1
        && request.resource.data.matchingSessions <= resource.data.matchingSessions + 1
        && request.resource.data.typingSessions <= studentProfileNumber(resource.data, 'typingSessions') + 1
        && studentProfileSessionsMatchTotal(request.resource.data)
        && (
          request.resource.data.listeningSessions - resource.data.listeningSessions
          + request.resource.data.speakingSessions - resource.data.speakingSessions
          + request.resource.data.matchingSessions - resource.data.matchingSessions
          + request.resource.data.typingSessions - studentProfileNumber(resource.data, 'typingSessions')
        ) == 1;
    }

    function isMatchingLeaderboardScopeKey(scopeKey, schoolId, grade, periodType, periodKey) {
      return scopeKey == schoolId + "__" + grade + "__" + periodType + "__" + periodKey;
    }

    function teacherDoc(uid) {
      return get(/databases/$(database)/documents/teachers/$(uid));
    }

    function teacherDocExists(uid) {
      return exists(/databases/$(database)/documents/teachers/$(uid));
    }

    function isTeacherForSchool(schoolId) {
      return isSignedIn()
        && teacherDocExists(request.auth.uid)
        && teacherDoc(request.auth.uid).data.isActive == true
        && teacherDoc(request.auth.uid).data.schoolId == schoolId;
    }

    function isMatchingLeaderboardDocument(data) {
      return data.keys().hasOnly([
          'scopeKey',
          'schoolId',
          'schoolName',
          'grade',
          'studentName',
          'studentNameNormalized',
          'periodType',
          'periodKey',
          'score',
          'elapsedSeconds',
          'solvedPairs',
          'createdAt',
          'updatedAt'
        ])
        && data.scopeKey is string
        && data.scopeKey.size() > 0
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isMatchingLeaderboardPeriodType(data.periodType)
        && data.periodKey is string
        && data.periodKey.size() > 0
        && isMatchingLeaderboardScopeKey(
          data.scopeKey,
          data.schoolId,
          data.grade,
          data.periodType,
          data.periodKey
        )
        && isNonNegativeNumber(data.score)
        && isNonNegativeNumber(data.elapsedSeconds)
        && isNonNegativeNumber(data.solvedPairs);
    }

    function isMatchingLeaderboardStudentWrite() {
      return isMatchingLeaderboardDocument(request.resource.data)
        && request.resource.data.scopeKey == request.resource.data.schoolId + "__" + request.resource.data.grade + "__" + request.resource.data.periodType + "__" + request.resource.data.periodKey;
    }

    function isMatchingLeaderboardTeacherCreate(studentKey) {
      return isMatchingLeaderboardDocument(request.resource.data)
        && isTeacherForSchool(request.resource.data.schoolId)
        && studentKey == request.resource.data.studentNameNormalized;
    }

    function isMatchingLeaderboardTeacherUpdate(studentKey) {
      return isMatchingLeaderboardTeacherCreate(studentKey)
        && resource.data.schoolId == request.resource.data.schoolId
        && resource.data.grade == request.resource.data.grade
        && resource.data.periodType == request.resource.data.periodType
        && resource.data.periodKey == request.resource.data.periodKey;
    }

    function isMatchingLeaderboardTeacherDelete() {
      return isTeacherForSchool(resource.data.schoolId);
    }

    function isFishingLeaderboardDocument(data) {
      return data.keys().hasOnly([
          'scopeKey',
          'schoolId',
          'schoolName',
          'grade',
          'studentName',
          'studentNameNormalized',
          'periodType',
          'periodKey',
          'score',
          'elapsedSeconds',
          'correctCount',
          'wrongCount',
          'missCount',
          'createdAt',
          'updatedAt'
        ])
        && data.scopeKey is string
        && data.scopeKey.size() > 0
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isMatchingLeaderboardPeriodType(data.periodType)
        && data.periodKey is string
        && data.periodKey.size() > 0
        && isMatchingLeaderboardScopeKey(
          data.scopeKey,
          data.schoolId,
          data.grade,
          data.periodType,
          data.periodKey
        )
        && isNonNegativeNumber(data.score)
        && isNonNegativeNumber(data.elapsedSeconds)
        && isNonNegativeNumber(data.correctCount)
        && isNonNegativeNumber(data.wrongCount)
        && isNonNegativeNumber(data.missCount);
    }

    function isFishingLeaderboardStudentWrite() {
      return isFishingLeaderboardDocument(request.resource.data)
        && request.resource.data.scopeKey == request.resource.data.schoolId + "__" + request.resource.data.grade + "__" + request.resource.data.periodType + "__" + request.resource.data.periodKey;
    }

    function isFishingLeaderboardTeacherCreate(studentKey) {
      return isFishingLeaderboardDocument(request.resource.data)
        && isTeacherForSchool(request.resource.data.schoolId)
        && studentKey == request.resource.data.studentNameNormalized;
    }

    function isFishingLeaderboardTeacherUpdate(studentKey) {
      return isFishingLeaderboardTeacherCreate(studentKey)
        && resource.data.schoolId == request.resource.data.schoolId
        && resource.data.grade == request.resource.data.grade
        && resource.data.periodType == request.resource.data.periodType
        && resource.data.periodKey == request.resource.data.periodKey;
    }

    function isFishingLeaderboardTeacherDelete() {
      return isTeacherForSchool(resource.data.schoolId);
    }

    function isTypingLeaderboardDocument(data) {
      return data.keys().hasOnly([
          'scopeKey',
          'schoolId',
          'schoolName',
          'grade',
          'studentName',
          'studentNameNormalized',
          'periodType',
          'periodKey',
          'score',
          'elapsedSeconds',
          'questionCount',
          'correctCount',
          'accuracy',
          'hintUsedCount',
          'bestCombo',
          'createdAt',
          'updatedAt'
        ])
        && data.scopeKey is string
        && data.scopeKey.size() > 0
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isMatchingLeaderboardPeriodType(data.periodType)
        && data.periodKey is string
        && data.periodKey.size() > 0
        && isMatchingLeaderboardScopeKey(
          data.scopeKey,
          data.schoolId,
          data.grade,
          data.periodType,
          data.periodKey
        )
        && isNonNegativeNumber(data.score)
        && isNonNegativeNumber(data.elapsedSeconds)
        && isNonNegativeNumber(data.questionCount)
        && isNonNegativeNumber(data.correctCount)
        && isNonNegativeNumber(data.accuracy)
        && isNonNegativeNumber(data.hintUsedCount)
        && isNonNegativeNumber(data.bestCombo);
    }

    function isTypingLeaderboardStudentWrite() {
      return isTypingLeaderboardDocument(request.resource.data)
        && request.resource.data.scopeKey == request.resource.data.schoolId + "__" + request.resource.data.grade + "__" + request.resource.data.periodType + "__" + request.resource.data.periodKey;
    }

    function isTypingLeaderboardTeacherCreate(studentKey) {
      return isTypingLeaderboardDocument(request.resource.data)
        && isTeacherForSchool(request.resource.data.schoolId)
        && studentKey == request.resource.data.studentNameNormalized;
    }

    function isTypingLeaderboardTeacherUpdate(studentKey) {
      return isTypingLeaderboardTeacherCreate(studentKey)
        && resource.data.schoolId == request.resource.data.schoolId
        && resource.data.grade == request.resource.data.grade
        && resource.data.periodType == request.resource.data.periodType
        && resource.data.periodKey == request.resource.data.periodKey;
    }

    function isTypingLeaderboardTeacherDelete() {
      return isTeacherForSchool(resource.data.schoolId);
    }

    function isTypingLeaderboardStudentImprovement() {
      return request.resource.data.score > resource.data.score
        || (
          request.resource.data.score == resource.data.score
          && request.resource.data.accuracy > resource.data.accuracy
        )
        || (
          request.resource.data.score == resource.data.score
          && request.resource.data.accuracy == resource.data.accuracy
          && request.resource.data.elapsedSeconds < resource.data.elapsedSeconds
        )
        || (
          request.resource.data.score == resource.data.score
          && request.resource.data.accuracy == resource.data.accuracy
          && request.resource.data.elapsedSeconds == resource.data.elapsedSeconds
          && request.resource.data.bestCombo > resource.data.bestCombo
        );
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['name', 'normalizedName', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.normalizedName is string;
      allow update, delete: if false;
    }

    match /teachers/{teacherId} {
      allow read: if resource.data.isActive == true || isTeacherOwner(teacherId);
      allow create, update: if isTeacherOwner(teacherId)
        && request.resource.data.keys().hasOnly([
          'teacherName',
          'schoolId',
          'schoolName',
          'isActive',
          'gradePublishers',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.teacherName is string
        && request.resource.data.schoolId is string
        && request.resource.data.schoolName is string
        && request.resource.data.isActive is bool
        && (
          !request.resource.data.keys().hasAny(['gradePublishers'])
          || request.resource.data.gradePublishers is map
        );
      allow delete: if isTeacherOwner(teacherId);
    }

    match /studentProfiles/{profileId} {
      allow get: if true;
      allow list: if false;

      allow create: if isStudentProfileWrite(profileId)
        && request.resource.data.totalSessions == 1
        && isStudentProfileFirstSessionShape(request.resource.data);

      allow update: if isStudentProfileWrite(profileId)
        && resource.data.schoolId == request.resource.data.schoolId
        && resource.data.grade == request.resource.data.grade
        && resource.data.studentNameNormalized == request.resource.data.studentNameNormalized
        && resource.data.createdAt == request.resource.data.createdAt
        && request.resource.data.totalSessions == resource.data.totalSessions + 1
        && isStudentProfileSingleSessionAdvance()
        && request.resource.data.listeningBestScore >= resource.data.listeningBestScore
        && request.resource.data.listeningBestCorrectCount >= resource.data.listeningBestCorrectCount
        && request.resource.data.speakingBestScore >= resource.data.speakingBestScore
        && request.resource.data.speakingBestCorrectCount >= resource.data.speakingBestCorrectCount
        && request.resource.data.matchingBestScore >= resource.data.matchingBestScore
        && (
          request.resource.data.matchingBestScore > resource.data.matchingBestScore
          || request.resource.data.matchingBestTime <= resource.data.matchingBestTime
        )
        && request.resource.data.typingBestScore >= studentProfileNumber(resource.data, 'typingBestScore')
        && request.resource.data.typingBestCorrectCount >= studentProfileNumber(resource.data, 'typingBestCorrectCount')
        && request.resource.data.typingBestAccuracy >= studentProfileNumber(resource.data, 'typingBestAccuracy')
        && request.resource.data.typingBestCombo >= studentProfileNumber(resource.data, 'typingBestCombo')
        && request.resource.data.typingBestElapsedSeconds >= 0
        && (request.resource.data.typingLastPlayedAt == null || request.resource.data.typingLastPlayedAt is timestamp)
        && request.resource.data.earnedBadges.hasAll(resource.data.earnedBadges)
        && request.resource.data.earnedBadges.size() >= resource.data.earnedBadges.size();

      allow delete: if false;
    }

    match /vocabularySets/{setId} {
      allow read: if isPublishedSet() || (
        isSignedIn() && resource.data.ownerUid == request.auth.uid
      );

      allow create, update: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'ownerUid',
          'schoolId',
          'schoolName',
          'teacherName',
          'grade',
          'unit',
          'publisher',
          'published',
          'sourceType',
          'items',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.schoolId is string
        && request.resource.data.schoolName is string
        && request.resource.data.teacherName is string
        && request.resource.data.grade is string
        && request.resource.data.unit is string
        && (
          !request.resource.data.keys().hasAny(['publisher'])
          || request.resource.data.publisher is string
        )
        && request.resource.data.published is bool
        && request.resource.data.sourceType is string
        && request.resource.data.items is list;

      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /matchingLeaderboards/{scopeKey} {
      allow read, write: if false;

      match /entries/{studentKey} {
        allow read: if true;

        allow create: if (
          isMatchingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
        ) || (
          isMatchingLeaderboardTeacherCreate(studentKey)
          && scopeKey == request.resource.data.scopeKey
        );

        allow update: if isMatchingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
          && resource.data.scopeKey == request.resource.data.scopeKey
          && resource.data.schoolId == request.resource.data.schoolId
          && resource.data.schoolName == request.resource.data.schoolName
          && resource.data.grade == request.resource.data.grade
          && resource.data.studentNameNormalized == request.resource.data.studentNameNormalized
          && resource.data.periodType == request.resource.data.periodType
          && resource.data.periodKey == request.resource.data.periodKey
          && request.resource.data.score > resource.data.score;

        allow update: if isMatchingLeaderboardTeacherUpdate(studentKey)
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized;

        allow delete: if isMatchingLeaderboardTeacherDelete();
      }
    }

    match /fishingLeaderboards/{scopeKey} {
      allow read, write: if false;

      match /entries/{studentKey} {
        allow read: if true;

        allow create: if (
          isFishingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
        ) || (
          isFishingLeaderboardTeacherCreate(studentKey)
          && scopeKey == request.resource.data.scopeKey
        );

        allow update: if isFishingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
          && resource.data.scopeKey == request.resource.data.scopeKey
          && resource.data.schoolId == request.resource.data.schoolId
          && resource.data.schoolName == request.resource.data.schoolName
          && resource.data.grade == request.resource.data.grade
          && resource.data.studentNameNormalized == request.resource.data.studentNameNormalized
          && resource.data.periodType == request.resource.data.periodType
          && resource.data.periodKey == request.resource.data.periodKey
          && request.resource.data.score > resource.data.score;

        allow update: if isFishingLeaderboardTeacherUpdate(studentKey)
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized;

        allow delete: if isFishingLeaderboardTeacherDelete();
      }
    }

    match /typingLeaderboards/{scopeKey} {
      allow read, write: if false;

      match /entries/{studentKey} {
        allow read: if true;

        allow create: if (
          isTypingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
        ) || (
          isTypingLeaderboardTeacherCreate(studentKey)
          && scopeKey == request.resource.data.scopeKey
        );

        allow update: if isTypingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
          && resource.data.scopeKey == request.resource.data.scopeKey
          && resource.data.schoolId == request.resource.data.schoolId
          && resource.data.schoolName == request.resource.data.schoolName
          && resource.data.grade == request.resource.data.grade
          && resource.data.studentNameNormalized == request.resource.data.studentNameNormalized
          && resource.data.periodType == request.resource.data.periodType
          && resource.data.periodKey == request.resource.data.periodKey
          && isTypingLeaderboardStudentImprovement();

        allow update: if isTypingLeaderboardTeacherUpdate(studentKey)
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized;

        allow delete: if isTypingLeaderboardTeacherDelete();
      }
    }

    function bingoSessionDoc(sessionId) {
      return get(/databases/$(database)/documents/bingoSessions/$(sessionId));
    }

    function bingoSessionExists(sessionId) {
      return exists(/databases/$(database)/documents/bingoSessions/$(sessionId));
    }

    function isBingoBoardSize(boardSize) {
      return boardSize == 3 || boardSize == 4;
    }

    function isBingoSessionMode(mode) {
      return mode == 'manual' || mode == 'tts';
    }

    function isBingoSessionStatus(status) {
      return status == 'waiting' || status == 'live' || status == 'finished';
    }

    function isBingoSessionDocument(data) {
      return data.keys().hasOnly([
          'sessionCode',
          'teacherUserId',
          'teacherName',
          'schoolId',
          'schoolName',
          'grade',
          'unit',
          'publisher',
          'selectedUnits',
          'selectedUnitLabels',
          'requiredCellCount',
          'mode',
          'boardSize',
          'status',
          'activeWordId',
          'activeWordText',
          'activeWordMeaning',
          'callSequence',
          'calledWordIds',
          'vocabularyItems',
          'createdAt',
          'updatedAt',
          'finishedAt',
          'finishedBy'
        ])
        && data.sessionCode is string
        && data.sessionCode.size() > 0
        && data.teacherUserId is string
        && data.teacherUserId.size() > 0
        && data.teacherName is string
        && data.teacherName.size() > 0
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.unit is string
        && data.unit.size() > 0
        && data.publisher is string
        && data.selectedUnits is list
        && data.selectedUnits.size() > 0
        && data.selectedUnitLabels is list
        && data.selectedUnitLabels.size() > 0
        && data.requiredCellCount is int
        && data.requiredCellCount >= 9
        && data.mode is string
        && isBingoSessionMode(data.mode)
        && isBingoBoardSize(data.boardSize)
        && data.requiredCellCount == data.boardSize * data.boardSize
        && data.status is string
        && isBingoSessionStatus(data.status)
        && data.activeWordId is string
        && data.activeWordText is string
        && data.activeWordMeaning is string
        && data.callSequence is list
        && data.calledWordIds is list
        && data.vocabularyItems is list
        && data.vocabularyItems.size() >= 9
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && (data.finishedAt == null || data.finishedAt is timestamp)
        && data.finishedBy is string;
    }

    function isBingoSessionCreate(sessionId) {
      return isSignedIn()
        && request.resource.data.sessionCode == sessionId
        && request.resource.data.teacherUserId == request.auth.uid
        && isTeacherForSchool(request.resource.data.schoolId)
        && isBingoSessionDocument(request.resource.data)
        && request.resource.data.status == 'live'
        && request.resource.data.activeWordId == ''
        && request.resource.data.activeWordText == ''
        && request.resource.data.activeWordMeaning == ''
        && request.resource.data.callSequence.size() == 0
        && request.resource.data.calledWordIds.size() == 0
        && request.resource.data.finishedAt == null
        && request.resource.data.finishedBy == '';
    }

    function isBingoSessionUpdate(sessionId) {
      return isSignedIn()
        && bingoSessionExists(sessionId)
        && bingoSessionDoc(sessionId).data.teacherUserId == request.auth.uid
        && isTeacherForSchool(request.resource.data.schoolId)
        && isBingoSessionDocument(request.resource.data)
        && request.resource.data.sessionCode == sessionId
        && request.resource.data.teacherUserId == resource.data.teacherUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.schoolName == resource.data.schoolName
        && request.resource.data.grade == resource.data.grade
        && request.resource.data.unit == resource.data.unit
        && request.resource.data.publisher == resource.data.publisher
        && request.resource.data.selectedUnits == resource.data.selectedUnits
        && request.resource.data.selectedUnitLabels == resource.data.selectedUnitLabels
        && request.resource.data.requiredCellCount == resource.data.requiredCellCount
        && request.resource.data.mode == resource.data.mode
        && request.resource.data.boardSize == resource.data.boardSize
        && request.resource.data.vocabularyItems == resource.data.vocabularyItems
        && request.resource.data.activeWordId is string
        && request.resource.data.activeWordText is string
        && request.resource.data.activeWordMeaning is string
        && request.resource.data.callSequence is list
        && request.resource.data.calledWordIds is list
        && isBingoSessionStatus(request.resource.data.status);
    }

    function isBingoPlayerCommonKeys(data) {
      return data.keys().hasOnly([
          'studentName',
          'studentNameNormalized',
          'boardSize',
          'requiredCellCount',
          'setupStatus',
          'availableWords',
          'boardCells',
          'boardWordIds',
          'markedWordIds',
          'bingoLines',
          'completedLineKeys',
          'hasBingo',
          'bingoRank',
          'setupStartedAt',
          'setupCompletedAt',
          'joinedAt',
          'updatedAt'
        ])
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isBingoBoardSize(data.boardSize)
        && data.requiredCellCount is int
        && data.requiredCellCount == data.boardSize * data.boardSize
        && data.setupStatus is string
        && data.boardCells is list
        && data.boardWordIds is list
        && data.boardCells.size() == data.boardSize * data.boardSize
        && data.markedWordIds is list
        && data.bingoLines is int
        && data.bingoLines >= 0
        && data.completedLineKeys is list
        && data.hasBingo is bool
        && (data.bingoRank == null || data.bingoRank is int)
        && data.availableWords is list
        && data.availableWords.size() == data.boardSize * data.boardSize
        && (data.setupStartedAt == null || data.setupStartedAt is timestamp)
        && (data.setupCompletedAt == null || data.setupCompletedAt is timestamp)
        && data.joinedAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isBingoPlayerSetupDraftDocument(data) {
      return isBingoPlayerCommonKeys(data)
        && data.setupStatus == 'arranging'
        && data.boardWordIds.size() <= data.boardSize * data.boardSize
        && data.markedWordIds.size() == 0
        && data.bingoLines == 0
        && data.completedLineKeys.size() == 0
        && data.hasBingo == false
        && data.bingoRank == null
        && data.setupStartedAt is timestamp
        && data.setupCompletedAt == null;
    }

    function isBingoPlayerMarkedUpdateDocument(data) {
      return isBingoPlayerCommonKeys(data)
        && data.setupStatus == 'ready'
        && data.boardWordIds.size() == data.boardSize * data.boardSize
        && data.completedLineKeys.size() == data.bingoLines
        && data.hasBingo == (data.bingoLines >= 3);
    }

    function isBingoPlayerDocument(data) {
      return isBingoPlayerSetupDraftDocument(data) || isBingoPlayerMarkedUpdateDocument(data);
    }

    function bingoCellMarked(boardCells, markedWordIds, index) {
      return boardCells[index].wordId is string
        && markedWordIds.hasAny([boardCells[index].wordId]);
    }

    function bingoLineCount3(boardCells, markedWordIds) {
      return (
        (bingoCellMarked(boardCells, markedWordIds, 0) && bingoCellMarked(boardCells, markedWordIds, 1) && bingoCellMarked(boardCells, markedWordIds, 2) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 3) && bingoCellMarked(boardCells, markedWordIds, 4) && bingoCellMarked(boardCells, markedWordIds, 5) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 6) && bingoCellMarked(boardCells, markedWordIds, 7) && bingoCellMarked(boardCells, markedWordIds, 8) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 0) && bingoCellMarked(boardCells, markedWordIds, 3) && bingoCellMarked(boardCells, markedWordIds, 6) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 1) && bingoCellMarked(boardCells, markedWordIds, 4) && bingoCellMarked(boardCells, markedWordIds, 7) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 2) && bingoCellMarked(boardCells, markedWordIds, 5) && bingoCellMarked(boardCells, markedWordIds, 8) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 0) && bingoCellMarked(boardCells, markedWordIds, 4) && bingoCellMarked(boardCells, markedWordIds, 8) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 2) && bingoCellMarked(boardCells, markedWordIds, 4) && bingoCellMarked(boardCells, markedWordIds, 6) ? 1 : 0)
      );
    }

    function bingoLineCount4(boardCells, markedWordIds) {
      return (
        (bingoCellMarked(boardCells, markedWordIds, 0) && bingoCellMarked(boardCells, markedWordIds, 1) && bingoCellMarked(boardCells, markedWordIds, 2) && bingoCellMarked(boardCells, markedWordIds, 3) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 4) && bingoCellMarked(boardCells, markedWordIds, 5) && bingoCellMarked(boardCells, markedWordIds, 6) && bingoCellMarked(boardCells, markedWordIds, 7) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 8) && bingoCellMarked(boardCells, markedWordIds, 9) && bingoCellMarked(boardCells, markedWordIds, 10) && bingoCellMarked(boardCells, markedWordIds, 11) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 12) && bingoCellMarked(boardCells, markedWordIds, 13) && bingoCellMarked(boardCells, markedWordIds, 14) && bingoCellMarked(boardCells, markedWordIds, 15) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 0) && bingoCellMarked(boardCells, markedWordIds, 4) && bingoCellMarked(boardCells, markedWordIds, 8) && bingoCellMarked(boardCells, markedWordIds, 12) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 1) && bingoCellMarked(boardCells, markedWordIds, 5) && bingoCellMarked(boardCells, markedWordIds, 9) && bingoCellMarked(boardCells, markedWordIds, 13) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 2) && bingoCellMarked(boardCells, markedWordIds, 6) && bingoCellMarked(boardCells, markedWordIds, 10) && bingoCellMarked(boardCells, markedWordIds, 14) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 3) && bingoCellMarked(boardCells, markedWordIds, 7) && bingoCellMarked(boardCells, markedWordIds, 11) && bingoCellMarked(boardCells, markedWordIds, 15) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 0) && bingoCellMarked(boardCells, markedWordIds, 5) && bingoCellMarked(boardCells, markedWordIds, 10) && bingoCellMarked(boardCells, markedWordIds, 15) ? 1 : 0)
        + (bingoCellMarked(boardCells, markedWordIds, 3) && bingoCellMarked(boardCells, markedWordIds, 6) && bingoCellMarked(boardCells, markedWordIds, 9) && bingoCellMarked(boardCells, markedWordIds, 12) ? 1 : 0)
      );
    }

    function bingoLineCount(boardCells, markedWordIds, boardSize) {
      return boardSize == 3 ? bingoLineCount3(boardCells, markedWordIds)
        : boardSize == 4 ? bingoLineCount4(boardCells, markedWordIds)
        : 0;
    }

    function isBingoPlayerCreate(sessionId, playerId) {
      return bingoSessionExists(sessionId)
        && bingoSessionDoc(sessionId).data.status == 'live'
        && request.resource.data.studentNameNormalized == playerId
        && request.resource.data.boardSize == bingoSessionDoc(sessionId).data.boardSize
        && request.resource.data.requiredCellCount == bingoSessionDoc(sessionId).data.requiredCellCount
        && request.resource.data.setupStatus == 'arranging'
        && isBingoPlayerSetupDraftDocument(request.resource.data)
        && request.resource.data.markedWordIds.size() == 0
        && request.resource.data.bingoLines == 0
        && request.resource.data.completedLineKeys.size() == 0
        && request.resource.data.hasBingo == false
        && request.resource.data.bingoRank == null;
    }

    function isBingoPlayerDraftUpdate(sessionId, playerId) {
      return bingoSessionExists(sessionId)
        && bingoSessionDoc(sessionId).data.status == 'live'
        && resource.data.setupStatus == 'arranging'
        && request.resource.data.studentNameNormalized == playerId
        && request.resource.data.studentNameNormalized == resource.data.studentNameNormalized
        && request.resource.data.boardSize == resource.data.boardSize
        && request.resource.data.requiredCellCount == resource.data.requiredCellCount
        && request.resource.data.setupStatus == 'arranging'
        && request.resource.data.availableWords == resource.data.availableWords
        && request.resource.data.boardCells is list
        && request.resource.data.boardCells.size() == resource.data.boardCells.size()
        && request.resource.data.boardWordIds is list
        && request.resource.data.boardWordIds.size() <= request.resource.data.boardSize * request.resource.data.boardSize
        && request.resource.data.markedWordIds == resource.data.markedWordIds
        && request.resource.data.bingoLines == 0
        && request.resource.data.completedLineKeys.size() == 0
        && request.resource.data.hasBingo == false
        && request.resource.data.bingoRank == null
        && request.resource.data.joinedAt == resource.data.joinedAt
        && request.resource.data.setupStartedAt == resource.data.setupStartedAt
        && request.resource.data.setupCompletedAt == null
        && isBingoPlayerDocument(request.resource.data);
    }

    function isBingoPlayerFinalizeUpdate(sessionId, playerId) {
      return bingoSessionExists(sessionId)
        && bingoSessionDoc(sessionId).data.status == 'live'
        && resource.data.setupStatus == 'arranging'
        && request.resource.data.studentNameNormalized == playerId
        && request.resource.data.studentNameNormalized == resource.data.studentNameNormalized
        && request.resource.data.boardSize == resource.data.boardSize
        && request.resource.data.requiredCellCount == resource.data.requiredCellCount
        && request.resource.data.setupStatus == 'ready'
        && request.resource.data.availableWords == resource.data.availableWords
        && request.resource.data.boardCells is list
        && request.resource.data.boardCells.size() == resource.data.boardCells.size()
        && request.resource.data.boardWordIds is list
        && request.resource.data.boardWordIds.size() == request.resource.data.boardSize * request.resource.data.boardSize
        && request.resource.data.markedWordIds.size() == 0
        && request.resource.data.bingoLines == 0
        && request.resource.data.completedLineKeys.size() == 0
        && request.resource.data.hasBingo == false
        && request.resource.data.bingoRank == null
        && request.resource.data.joinedAt == resource.data.joinedAt
        && request.resource.data.setupStartedAt == resource.data.setupStartedAt
        && request.resource.data.setupCompletedAt is timestamp
        && isBingoPlayerMarkedUpdateDocument(request.resource.data);
    }

    function isBingoPlayerUpdate(sessionId, playerId) {
      return isBingoPlayerDraftUpdate(sessionId, playerId)
        || isBingoPlayerFinalizeUpdate(sessionId, playerId)
        || (
          bingoSessionExists(sessionId)
          && bingoSessionDoc(sessionId).data.status == 'live'
          && resource.data.setupStatus == 'ready'
          && request.resource.data.studentNameNormalized == resource.data.studentNameNormalized
          && request.resource.data.markedWordIds is list
          && request.resource.data.markedWordIds.hasAll(resource.data.markedWordIds)
          && request.resource.data.markedWordIds.size() <= resource.data.markedWordIds.size() + 1
          && request.resource.data.bingoLines >= resource.data.bingoLines
          && request.resource.data.bingoLines == request.resource.data.completedLineKeys.size()
          && request.resource.data.hasBingo == (request.resource.data.bingoLines >= 3)
        );
    }

    match /bingoSessions/{sessionId} {
      allow get: if true;
      allow list: if false;
      allow create: if isBingoSessionCreate(sessionId);
      allow update: if isBingoSessionUpdate(sessionId);
      allow delete: if false;

      match /players/{playerId} {
        allow get: if true;
        allow list: if bingoSessionExists(sessionId);
        allow create: if isBingoPlayerCreate(sessionId, playerId);
        allow update: if isBingoPlayerUpdate(sessionId, playerId);
        allow delete: if false;
      }
    }
  }
}

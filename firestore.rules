rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacherOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPublishedSet() {
      return resource.data.published == true;
    }

    function isMatchingLeaderboardPeriodType(periodType) {
      return periodType == 'week' || periodType == 'month' || periodType == 'year' || periodType == 'school_all';
    }

    function isNonNegativeNumber(value) {
      return (value is int || value is float) && value >= 0;
    }

    function isStudentBadgeId(badgeId) {
      return badgeId == 'first_challenge'
        || badgeId == 'listening_star'
        || badgeId == 'speaking_bravery'
        || badgeId == 'matching_speed'
        || badgeId == 'practice_keeper';
    }

    function isStudentProfileId(profileId, schoolId, grade, studentNameNormalized) {
      return profileId == schoolId + "__" + grade + "__" + studentNameNormalized;
    }

    function isStudentProfileDocument(data) {
      return data.keys().hasOnly([
          'schoolId',
          'schoolName',
          'grade',
          'studentName',
          'studentNameNormalized',
          'totalSessions',
          'listeningSessions',
          'speakingSessions',
          'matchingSessions',
          'listeningBestScore',
          'listeningBestCorrectCount',
          'speakingBestScore',
          'speakingBestCorrectCount',
          'matchingBestScore',
          'matchingBestTime',
          'earnedBadges',
          'createdAt',
          'updatedAt'
        ])
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isNonNegativeNumber(data.totalSessions)
        && isNonNegativeNumber(data.listeningSessions)
        && isNonNegativeNumber(data.speakingSessions)
        && isNonNegativeNumber(data.matchingSessions)
        && isNonNegativeNumber(data.listeningBestScore)
        && isNonNegativeNumber(data.listeningBestCorrectCount)
        && isNonNegativeNumber(data.speakingBestScore)
        && isNonNegativeNumber(data.speakingBestCorrectCount)
        && isNonNegativeNumber(data.matchingBestScore)
        && isNonNegativeNumber(data.matchingBestTime)
        && data.earnedBadges is list
        && data.earnedBadges.hasOnly([
          'first_challenge',
          'listening_star',
          'speaking_bravery',
          'matching_speed',
          'practice_keeper'
        ])
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isStudentProfileWrite(profileId) {
      return isStudentProfileDocument(request.resource.data)
        && isStudentProfileId(
          profileId,
          request.resource.data.schoolId,
          request.resource.data.grade,
          request.resource.data.studentNameNormalized
        );
    }

    function studentProfileSessionsMatchTotal(data) {
      return data.totalSessions
        == data.listeningSessions + data.speakingSessions + data.matchingSessions;
    }

    function isStudentProfileFirstSessionShape(data) {
      return studentProfileSessionsMatchTotal(data)
        && (
          (data.listeningSessions == 1 && data.speakingSessions == 0 && data.matchingSessions == 0)
          || (data.listeningSessions == 0 && data.speakingSessions == 1 && data.matchingSessions == 0)
          || (data.listeningSessions == 0 && data.speakingSessions == 0 && data.matchingSessions == 1)
        );
    }

    function isStudentProfileSingleSessionAdvance() {
      return request.resource.data.listeningSessions >= resource.data.listeningSessions
        && request.resource.data.speakingSessions >= resource.data.speakingSessions
        && request.resource.data.matchingSessions >= resource.data.matchingSessions
        && request.resource.data.listeningSessions <= resource.data.listeningSessions + 1
        && request.resource.data.speakingSessions <= resource.data.speakingSessions + 1
        && request.resource.data.matchingSessions <= resource.data.matchingSessions + 1
        && studentProfileSessionsMatchTotal(request.resource.data)
        && (
          request.resource.data.listeningSessions - resource.data.listeningSessions
          + request.resource.data.speakingSessions - resource.data.speakingSessions
          + request.resource.data.matchingSessions - resource.data.matchingSessions
        ) == 1;
    }

    function isMatchingLeaderboardScopeKey(scopeKey, schoolId, grade, periodType, periodKey) {
      return scopeKey == schoolId + "__" + grade + "__" + periodType + "__" + periodKey;
    }

    function teacherDoc(uid) {
      return get(/databases/$(database)/documents/teachers/$(uid));
    }

    function teacherDocExists(uid) {
      return exists(/databases/$(database)/documents/teachers/$(uid));
    }

    function isTeacherForSchool(schoolId) {
      return isSignedIn()
        && teacherDocExists(request.auth.uid)
        && teacherDoc(request.auth.uid).data.isActive == true
        && teacherDoc(request.auth.uid).data.schoolId == schoolId;
    }

    function isMatchingLeaderboardDocument(data) {
      return data.keys().hasOnly([
          'scopeKey',
          'schoolId',
          'schoolName',
          'grade',
          'studentName',
          'studentNameNormalized',
          'periodType',
          'periodKey',
          'score',
          'elapsedSeconds',
          'solvedPairs',
          'createdAt',
          'updatedAt'
        ])
        && data.scopeKey is string
        && data.scopeKey.size() > 0
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isMatchingLeaderboardPeriodType(data.periodType)
        && data.periodKey is string
        && data.periodKey.size() > 0
        && isMatchingLeaderboardScopeKey(
          data.scopeKey,
          data.schoolId,
          data.grade,
          data.periodType,
          data.periodKey
        )
        && isNonNegativeNumber(data.score)
        && isNonNegativeNumber(data.elapsedSeconds)
        && isNonNegativeNumber(data.solvedPairs);
    }

    function isMatchingLeaderboardStudentWrite() {
      return isMatchingLeaderboardDocument(request.resource.data)
        && request.resource.data.scopeKey == request.resource.data.schoolId + "__" + request.resource.data.grade + "__" + request.resource.data.periodType + "__" + request.resource.data.periodKey;
    }

    function isMatchingLeaderboardTeacherCreate(studentKey) {
      return isMatchingLeaderboardDocument(request.resource.data)
        && isTeacherForSchool(request.resource.data.schoolId)
        && studentKey == request.resource.data.studentNameNormalized;
    }

    function isMatchingLeaderboardTeacherUpdate(studentKey) {
      return isMatchingLeaderboardTeacherCreate(studentKey)
        && resource.data.schoolId == request.resource.data.schoolId
        && resource.data.grade == request.resource.data.grade
        && resource.data.periodType == request.resource.data.periodType
        && resource.data.periodKey == request.resource.data.periodKey;
    }

    function isMatchingLeaderboardTeacherDelete() {
      return isTeacherForSchool(resource.data.schoolId);
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['name', 'normalizedName', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.normalizedName is string;
      allow update, delete: if false;
    }

    match /teachers/{teacherId} {
      allow read: if resource.data.isActive == true || isTeacherOwner(teacherId);
      allow create, update: if isTeacherOwner(teacherId)
        && request.resource.data.keys().hasOnly([
          'teacherName',
          'schoolId',
          'schoolName',
          'isActive',
          'gradePublishers',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.teacherName is string
        && request.resource.data.schoolId is string
        && request.resource.data.schoolName is string
        && request.resource.data.isActive is bool
        && (
          !request.resource.data.keys().hasAny(['gradePublishers'])
          || request.resource.data.gradePublishers is map
        );
      allow delete: if isTeacherOwner(teacherId);
    }

    match /studentProfiles/{profileId} {
      allow get: if true;
      allow list: if false;

      allow create: if isStudentProfileWrite(profileId)
        && request.resource.data.totalSessions == 1
        && isStudentProfileFirstSessionShape(request.resource.data);

      allow update: if isStudentProfileWrite(profileId)
        && resource.data.schoolId == request.resource.data.schoolId
        && resource.data.grade == request.resource.data.grade
        && resource.data.studentNameNormalized == request.resource.data.studentNameNormalized
        && resource.data.createdAt == request.resource.data.createdAt
        && request.resource.data.totalSessions == resource.data.totalSessions + 1
        && isStudentProfileSingleSessionAdvance()
        && request.resource.data.listeningBestScore >= resource.data.listeningBestScore
        && request.resource.data.listeningBestCorrectCount >= resource.data.listeningBestCorrectCount
        && request.resource.data.speakingBestScore >= resource.data.speakingBestScore
        && request.resource.data.speakingBestCorrectCount >= resource.data.speakingBestCorrectCount
        && request.resource.data.matchingBestScore >= resource.data.matchingBestScore
        && (
          request.resource.data.matchingBestScore > resource.data.matchingBestScore
          || request.resource.data.matchingBestTime <= resource.data.matchingBestTime
        )
        && request.resource.data.earnedBadges.hasAll(resource.data.earnedBadges)
        && request.resource.data.earnedBadges.size() >= resource.data.earnedBadges.size();

      allow delete: if false;
    }

    match /vocabularySets/{setId} {
      allow read: if isPublishedSet() || (
        isSignedIn() && resource.data.ownerUid == request.auth.uid
      );

      allow create, update: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'ownerUid',
          'schoolId',
          'schoolName',
          'teacherName',
          'grade',
          'unit',
          'publisher',
          'published',
          'sourceType',
          'items',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.schoolId is string
        && request.resource.data.schoolName is string
        && request.resource.data.teacherName is string
        && request.resource.data.grade is string
        && request.resource.data.unit is string
        && (
          !request.resource.data.keys().hasAny(['publisher'])
          || request.resource.data.publisher is string
        )
        && request.resource.data.published is bool
        && request.resource.data.sourceType is string
        && request.resource.data.items is list;

      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /matchingLeaderboards/{scopeKey} {
      allow read, write: if false;

      match /entries/{studentKey} {
        allow read: if true;

        allow create: if (
          isMatchingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
        ) || (
          isMatchingLeaderboardTeacherCreate(studentKey)
          && scopeKey == request.resource.data.scopeKey
        );

        allow update: if isMatchingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
          && resource.data.scopeKey == request.resource.data.scopeKey
          && resource.data.schoolId == request.resource.data.schoolId
          && resource.data.schoolName == request.resource.data.schoolName
          && resource.data.grade == request.resource.data.grade
          && resource.data.studentNameNormalized == request.resource.data.studentNameNormalized
          && resource.data.periodType == request.resource.data.periodType
          && resource.data.periodKey == request.resource.data.periodKey
          && request.resource.data.score > resource.data.score;

        allow update: if isMatchingLeaderboardTeacherUpdate(studentKey)
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized;

        allow delete: if isMatchingLeaderboardTeacherDelete();
      }
    }
  }
}

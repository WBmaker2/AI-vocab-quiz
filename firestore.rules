rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacherOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isPublishedSet() {
      return resource.data.published == true;
    }

    function isMatchingLeaderboardPeriodType(periodType) {
      return periodType == 'week' || periodType == 'month' || periodType == 'year';
    }

    function isNonNegativeNumber(value) {
      return (value is int || value is float) && value >= 0;
    }

    function isMatchingLeaderboardScopeKey(scopeKey, schoolId, grade, periodType, periodKey) {
      return scopeKey == schoolId + "__" + grade + "__" + periodType + "__" + periodKey;
    }

    function teacherDoc(uid) {
      return get(/databases/$(database)/documents/teachers/$(uid));
    }

    function teacherDocExists(uid) {
      return exists(/databases/$(database)/documents/teachers/$(uid));
    }

    function isTeacherForSchool(schoolId) {
      return isSignedIn()
        && teacherDocExists(request.auth.uid)
        && teacherDoc(request.auth.uid).data.isActive == true
        && teacherDoc(request.auth.uid).data.schoolId == schoolId;
    }

    function isMatchingLeaderboardDocument(data) {
      return data.keys().hasOnly([
          'scopeKey',
          'schoolId',
          'schoolName',
          'grade',
          'studentName',
          'studentNameNormalized',
          'periodType',
          'periodKey',
          'score',
          'elapsedSeconds',
          'solvedPairs',
          'createdAt',
          'updatedAt'
        ])
        && data.scopeKey is string
        && data.scopeKey.size() > 0
        && data.schoolId is string
        && data.schoolId.size() > 0
        && data.schoolName is string
        && data.schoolName.size() > 0
        && data.grade is string
        && data.grade.size() > 0
        && data.studentName is string
        && data.studentName.size() > 0
        && data.studentNameNormalized is string
        && data.studentNameNormalized.size() > 0
        && isMatchingLeaderboardPeriodType(data.periodType)
        && data.periodKey is string
        && data.periodKey.size() > 0
        && isMatchingLeaderboardScopeKey(
          data.scopeKey,
          data.schoolId,
          data.grade,
          data.periodType,
          data.periodKey
        )
        && isNonNegativeNumber(data.score)
        && isNonNegativeNumber(data.elapsedSeconds)
        && isNonNegativeNumber(data.solvedPairs);
    }

    function isMatchingLeaderboardStudentWrite() {
      return isMatchingLeaderboardDocument(request.resource.data)
        && request.resource.data.scopeKey == request.resource.data.schoolId + "__" + request.resource.data.grade + "__" + request.resource.data.periodType + "__" + request.resource.data.periodKey;
    }

    function isMatchingLeaderboardTeacherCreate(studentKey) {
      return isMatchingLeaderboardDocument(request.resource.data)
        && isTeacherForSchool(request.resource.data.schoolId)
        && studentKey == request.resource.data.studentNameNormalized;
    }

    function isMatchingLeaderboardTeacherUpdate(studentKey) {
      return isMatchingLeaderboardTeacherCreate(studentKey)
        && resource.data.schoolId == request.resource.data.schoolId
        && resource.data.grade == request.resource.data.grade
        && resource.data.periodType == request.resource.data.periodType
        && resource.data.periodKey == request.resource.data.periodKey;
    }

    function isMatchingLeaderboardTeacherDelete() {
      return isTeacherForSchool(resource.data.schoolId);
    }

    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['name', 'normalizedName', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.normalizedName is string;
      allow update, delete: if false;
    }

    match /teachers/{teacherId} {
      allow read: if resource.data.isActive == true || isTeacherOwner(teacherId);
      allow create, update: if isTeacherOwner(teacherId)
        && request.resource.data.keys().hasOnly([
          'teacherName',
          'schoolId',
          'schoolName',
          'isActive',
          'gradePublishers',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.teacherName is string
        && request.resource.data.schoolId is string
        && request.resource.data.schoolName is string
        && request.resource.data.isActive is bool
        && (
          !request.resource.data.keys().hasAny(['gradePublishers'])
          || request.resource.data.gradePublishers is map
        );
      allow delete: if isTeacherOwner(teacherId);
    }

    match /vocabularySets/{setId} {
      allow read: if isPublishedSet() || (
        isSignedIn() && resource.data.ownerUid == request.auth.uid
      );

      allow create, update: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'ownerUid',
          'schoolId',
          'schoolName',
          'teacherName',
          'grade',
          'unit',
          'publisher',
          'published',
          'sourceType',
          'items',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.schoolId is string
        && request.resource.data.schoolName is string
        && request.resource.data.teacherName is string
        && request.resource.data.grade is string
        && request.resource.data.unit is string
        && (
          !request.resource.data.keys().hasAny(['publisher'])
          || request.resource.data.publisher is string
        )
        && request.resource.data.published is bool
        && request.resource.data.sourceType is string
        && request.resource.data.items is list;

      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /matchingLeaderboards/{scopeKey} {
      allow read, write: if false;

      match /entries/{studentKey} {
        allow read: if true;

        allow create: if (
          isMatchingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
        ) || (
          isMatchingLeaderboardTeacherCreate(studentKey)
          && scopeKey == request.resource.data.scopeKey
        );

        allow update: if isMatchingLeaderboardStudentWrite()
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized
          && resource.data.scopeKey == request.resource.data.scopeKey
          && resource.data.schoolId == request.resource.data.schoolId
          && resource.data.schoolName == request.resource.data.schoolName
          && resource.data.grade == request.resource.data.grade
          && resource.data.studentNameNormalized == request.resource.data.studentNameNormalized
          && resource.data.periodType == request.resource.data.periodType
          && resource.data.periodKey == request.resource.data.periodKey
          && request.resource.data.score > resource.data.score;

        allow update: if isMatchingLeaderboardTeacherUpdate(studentKey)
          && scopeKey == request.resource.data.scopeKey
          && studentKey == request.resource.data.studentNameNormalized;

        allow delete: if isMatchingLeaderboardTeacherDelete();
      }
    }
  }
}
